# Salin jadi ".env" lalu isi. File .env sudah masuk .gitignore.
# Muat ke shell sebelum menjalankan server:  set -a; . ./.env; set +a

# Token rahasia. Samakan dengan VPS_API_KEY di secrets.h firmware ESP32.
# Buat token acak: openssl rand -hex 24
API_KEY=ganti-dengan-token-acak-panjang

# Lokasi file database SQLite (opsional, default sensor.db).
DB_PATH=sensor.db
