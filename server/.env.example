# Salin jadi ".env" lalu isi. File .env sudah masuk .gitignore.
# Muat ke shell sebelum menjalankan server:  set -a; . ./.env; set +a

# Token rahasia. Samakan dengan VPS_API_KEY di secrets.h firmware ESP32.
# Buat token acak: openssl rand -hex 24
API_KEY=ganti-dengan-token-acak-panjang

# Connection string Postgres dari Supabase.
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI.
# Pakai "Connection pooler" (port 6543) untuk app; ganti [YOUR-PASSWORD] dengan
# password database project. Tidak ada default — server menolak jalan tanpa ini.
DATABASE_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
