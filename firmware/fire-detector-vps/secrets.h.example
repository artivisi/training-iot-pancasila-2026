// Salin file ini menjadi "secrets.h" (hapus akhiran .example), lalu isi.
// secrets.h sudah masuk .gitignore -> tidak ikut ter-commit.

#define WIFI_SSID  "nama-wifi"
#define WIFI_PASS  "password-wifi"

// Identitas device — bebas, tapi unik per kelompok (muncul di database).
#define DEVICE_ID  "esp32-grup1"

// Alamat endpoint server VPS. Untuk uji lokal pakai IP komputer di jaringan
// yang sama, mis. http://192.168.1.10:5000/api/readings
// Di VPS: http://ALAMAT-VPS:5000/api/readings  (atau https:// kalau sudah ada).
#define VPS_URL  "http://ALAMAT-VPS:5000/api/readings"

// Harus SAMA dengan API_KEY di server (.env).
#define VPS_API_KEY  "samakan-dengan-API_KEY-server"
