// Salin file ini menjadi "secrets.h" (hapus akhiran .example), lalu isi
// nilainya. File secrets.h sudah masuk .gitignore -> token & password TIDAK
// ikut ter-commit ke Git.
//
// Cara dapat token Blynk:
//   1. Buka https://blynk.cloud -> buat template baru.
//   2. Di template, buat 3 Datastream Virtual Pin (lihat tabel di workbook).
//   3. Buka Device -> Device Info -> salin BLYNK_TEMPLATE_ID,
//      BLYNK_TEMPLATE_NAME, dan BLYNK_AUTH_TOKEN.

#define BLYNK_TEMPLATE_ID    "TMPLxxxxxxxx"
#define BLYNK_TEMPLATE_NAME  "Fire Detector"
#define BLYNK_AUTH_TOKEN     "isi-token-device-dari-blynk"

// WiFi kampus / hotspot. Untuk WiFi kampus yang pakai login web (captive
// portal) ESP32 TIDAK bisa connect -> pakai hotspot HP sebagai ganti.
#define WIFI_SSID  "nama-wifi"
#define WIFI_PASS  "password-wifi"
